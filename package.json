{
  "name": "site",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check:base-path": "node scripts/check-base-path.mjs",
    "check:dist": "node scripts/check-dist.mjs",
    "check:public-boundary": "node scripts/check-public-boundary.mjs",
    "check:repo-contract": "node scripts/check-repo-contract.mjs",
    "check:tracked-files": "node scripts/check-tracked-files.mjs",
    "check:runtime-contract": "node scripts/check-runtime-contract.mjs",
    "check:css-contract": "node scripts/check-css-contract.mjs",
    "check:guards": "npm run check:dist && npm run check:public-boundary && npm run check:repo-contract && npm run check:tracked-files && npm run check:runtime-contract && npm run check:css-contract",
    "check": "astro check",
    "verify": "npm run check && npm run build && npm run check:guards",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^7.0.9"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^24.13.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": "2.8.3"
    }
  }
}
