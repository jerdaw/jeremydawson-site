# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.*

# Local/private maintainer notes. Do not commit plaintext private notes.
private/**/*.md
private/**/*.txt
private/**/*.log
private/**/*.local.*
.private/

# Encrypted private notes may be tracked only if an encryption workflow is intentionally used.
!private/**/*.age
!private/**/*.md.age
!private/**/*.enc.md

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Local tool config (launch configs, permissions, plans)
.claude/
.codex/
.agents/
.worktrees/
