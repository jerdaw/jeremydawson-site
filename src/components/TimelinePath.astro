---
// TimelinePath.astro — full-page animated bezier path.
// All path geometry is computed at runtime in enhancements.js.
---

<svg
  class="timeline-path"
  id="timeline-path-svg"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id="prism-fill-gradient" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="rgba(0, 179, 189, 0.06)" />
      <stop offset="50%" stop-color="rgba(255, 255, 255, 0.03)" />
      <stop offset="100%" stop-color="rgba(196, 124, 191, 0.06)" />
    </linearGradient>

    <linearGradient id="path-gradient" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="0" y2="1000">
      <stop offset="0%" stop-color="#da6c62" />
      <stop offset="50%" stop-color="#00B3BD" />
      <stop offset="100%" stop-color="#5288BA" />
    </linearGradient>

    <radialGradient id="terminus-gradient" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#00B3BD" stop-opacity="0.9" />
      <stop offset="50%" stop-color="#da6c62" stop-opacity="0.4" />
      <stop offset="100%" stop-color="#da6c62" stop-opacity="0" />
    </radialGradient>
  </defs>

  <!-- Faint background track -->
  <path
    id="timeline-track"
    class="timeline-path__track"
    fill="none"
  />

  <!-- Ghost/echo paths -->
  <g id="ghost-paths"></g>

  <!-- Split paths (About section parallel lines) -->
  <g id="split-paths"></g>

  <!-- Portal gateway -->
  <g id="portal-group"></g>

  <!-- Fan-out paths (Projects section branches) -->
  <g id="fan-paths"></g>

  <!-- Prism refraction (Research section) -->
  <g id="prism-paths"></g>
  <g id="prism-group"></g>

  <!-- Main animated draw path -->
  <path
    id="timeline-draw"
    class="timeline-path__draw"
    fill="none"
    stroke="url(#path-gradient)"
  />

  <!-- Branch filaments at nodes -->
  <g id="branch-paths"></g>

  <!-- Section transition nodes -->
  <g id="section-nodes"></g>

  <!-- Terminus orb -->
  <circle
    id="terminus-orb"
    r="0"
    fill="url(#terminus-gradient)"
    opacity="0"
  />

  <!-- Leading-edge dot -->
  <circle
    id="leading-dot"
    r="6"
    fill="#da6c62"
    opacity="0"
  />
</svg>
