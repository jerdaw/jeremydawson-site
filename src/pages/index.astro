---
import Enhancements from "../components/Enhancements.astro";
import ExperienceTimeline from "../components/ExperienceTimeline.astro";
import ProjectCards from "../components/ProjectCards.astro";
import SignalField from "../components/SignalField.astro";
import SiteHeader from "../components/SiteHeader.astro";
import {
  about,
  contactLinks,
  contactSection,
  experience,
  experienceSection,
  footerText,
  featuredProjects,
  hero,
  navLinks,
  privateEmailContact,
  projectsSection,
  researchCommunication,
  researchSection,
  siteMeta,
} from "../data/profile";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title={siteMeta.title}
  description={siteMeta.description}
  siteName={siteMeta.siteName}
  image={siteMeta.socialImage.path}
  imageAlt={siteMeta.socialImage.alt}
  imageWidth={siteMeta.socialImage.width}
  imageHeight={siteMeta.socialImage.height}
>
  <div class="site-shell">
    <SiteHeader navLinks={navLinks} />

    <main data-scroll-root>
      <section class="section hero" id="top" data-section="top">
        <div class="hero__copy observe is-visible" data-reveal>
          <p class="hero__eyebrow">{hero.eyebrow}</p>
          <h1 class="hero__title">{hero.headline}</h1>
          <p class="hero__intro">{hero.intro}</p>

          <div class="hero__actions">
            <a class="button button--primary" href={hero.primaryCta.href}>
              {hero.primaryCta.label}
            </a>
            <a class="button button--secondary" href={hero.secondaryCta.href}>
              {hero.secondaryCta.label}
            </a>
          </div>

          <dl class="hero__highlights">
            {hero.highlights.map((item) => (
              <div class="hero__stat">
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        </div>

        <SignalField />
      </section>

      <section class="section" id="about" data-section="about">
        <p class="section__eyebrow">{about.eyebrow}</p>
        <div class="about">
          <div class="about__body observe" data-reveal>
            <h2 class="section__title">{about.title}</h2>
            <p class="about__lead">{about.lead}</p>
            {about.body.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          <ul class="about__principles observe" data-reveal aria-label="Working principles">
            {about.principles.map((principle) => (
              <li>{principle}</li>
            ))}
          </ul>
        </div>
      </section>

      <section class="section" id="experience" data-section="experience">
        <div class="experience-shell">
          <aside class="experience-shell__aside observe" data-reveal>
            <div class="experience-shell__panel">
              <p class="section__eyebrow">{experienceSection.eyebrow}</p>
              <h2 class="section__title">{experienceSection.title}</h2>
              <p class="section__lede">{experienceSection.lede}</p>
              <div class="experience-shell__rail" aria-hidden="true"></div>
            </div>
          </aside>

          <ExperienceTimeline entries={experience} />
        </div>
      </section>

      <section class="section" id="projects" data-section="projects">
        <p class="section__eyebrow">{projectsSection.eyebrow}</p>
        <h2 class="section__title">{projectsSection.title}</h2>
        <p class="section__lede">{projectsSection.lede}</p>

        <div style="margin-top: 2rem;">
          <ProjectCards projects={featuredProjects} />
        </div>
      </section>

      <section class="section" id="research" data-section="research">
        <p class="section__eyebrow">{researchSection.eyebrow}</p>
        <h2 class="section__title">{researchSection.title}</h2>
        <p class="section__lede">{researchSection.lede}</p>

        <div class="speaking-grid">
          {researchCommunication.map((entry) => (
            <article class="speaking-card observe" data-reveal>
              <p>
                {entry.date} · {entry.format}
              </p>
              <h3>{entry.title}</h3>
              <p>{entry.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="contact" data-section="contact">
        <p class="section__eyebrow">{contactSection.eyebrow}</p>
        <h2 class="section__title">{contactSection.title}</h2>
        <p class="section__lede">{contactSection.lede}</p>

        <div class="contact-grid">
          <article class="contact-card contact-card--private observe" data-reveal data-email-card>
            <div class="contact-card__label">{privateEmailContact.label}</div>
            <div
              class="contact-card__value"
              data-email-value
              aria-live="polite"
            >
              {privateEmailContact.placeholder}
            </div>
            <div class="contact-card__detail" data-email-detail>
              {privateEmailContact.detail}
            </div>
            <div class="contact-card__actions">
              <button
                type="button"
                class="contact-card__button"
                data-email-reveal
              >
                {privateEmailContact.revealLabel}
              </button>
              <a
                href="#contact"
                class="contact-card__button contact-card__button--secondary"
                data-email-link
                hidden
                rel="nofollow"
              >
                {privateEmailContact.mailLabel}
              </a>
              <button
                type="button"
                class="contact-card__button contact-card__button--secondary"
                data-email-copy
                hidden
              >
                {privateEmailContact.copyLabel}
              </button>
            </div>
          </article>

          {contactLinks.map((link) => (
            <a href={link.href} class="contact-card observe" data-reveal>
              <div class="contact-card__label">{link.label}</div>
              <div class="contact-card__value">{link.value}</div>
              <div class="contact-card__detail">{link.detail}</div>
            </a>
          ))}
        </div>
      </section>
    </main>

    <footer class="footer">{footerText}</footer>
  </div>

  <Enhancements />
</BaseLayout>
