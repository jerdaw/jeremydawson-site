---
import { comingSoon, siteMeta } from "../data/profile";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title={siteMeta.title}
  description={siteMeta.description}
  siteName={siteMeta.siteName}
>
  <main class="coming-soon" aria-labelledby="coming-soon-title">
    <section class="coming-soon__panel">
      <img
        class="coming-soon__mark"
        src={`${import.meta.env.BASE_URL}favicon.svg`}
        alt=""
        aria-hidden="true"
      />
      <p class="coming-soon__eyebrow">{comingSoon.eyebrow}</p>
      <h1 id="coming-soon-title">{comingSoon.title}</h1>
      <p class="coming-soon__message">{comingSoon.message}</p>
      <p class="coming-soon__note">{comingSoon.note}</p>
    </section>
  </main>
</BaseLayout>
