---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteMeta } from "../data/profile";
---

<BaseLayout
  title={`Page not found | ${siteMeta.title}`}
  description={siteMeta.description}
  siteName={siteMeta.siteName}
>
  <main class="coming-soon" aria-labelledby="not-found-title">
    <section class="coming-soon__panel">
      <img
        class="coming-soon__mark"
        src={`${import.meta.env.BASE_URL}favicon.svg`}
        alt=""
        aria-hidden="true"
      />
      <p class="coming-soon__eyebrow">404</p>
      <h1 id="not-found-title">Page not found.</h1>
      <p class="coming-soon__message">
        That page is gone for now.
      </p>
      <p class="coming-soon__note">
        <a href={import.meta.env.BASE_URL}>Return to the temporary homepage.</a>
      </p>
    </section>
  </main>
</BaseLayout>
